{
  "name": "重庆劳动法生产评测集 v1",
  "datasetType": "production_eval_v1",
  "purpose": "用于上线前验证回答质量保护、低置信度转人工复核和重庆语境下的保守输出边界。",
  "releaseGate": {
    "requiredPassRate": 1.0
  },
  "cases": [
    {
      "id": "prod-wage-complete-yubei",
      "category": "clear_claim",
      "narrative": "我在重庆渝北一家物流公司上班，公司拖欠我两个月工资，有银行流水、工资条和打卡记录，想知道仲裁前先准备什么。",
      "expectedScenarioLabel": "拖欠工资",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.7,
      "expectedHandoffRequired": false,
      "mustContain": ["重庆本地程序路径", "工资流水", "考勤记录"],
      "mustAvoid": ["稳赢", "包赢", "偏向劳动者"],
      "requireFollowUp": false
    },
    {
      "id": "prod-termination-fragmented-jiangbei",
      "category": "low_confidence_handoff",
      "narrative": "我在重庆江北被公司突然移出工作群，说以后不用来了，我现在只保留了聊天截图，其他材料还没整理。",
      "expectedScenarioLabel": "违法解除/辞退",
      "expectedRiskLevel": "high",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.5,
      "expectedHandoffRequired": true,
      "mustContain": ["解除通知", "建议人工复核", "重庆本地程序路径"],
      "mustAvoid": ["一定支持", "公司肯定败诉"],
      "requireFollowUp": true
    },
    {
      "id": "prod-contract-backfill-shapingba",
      "category": "clear_claim",
      "narrative": "我在重庆沙坪坝入职后一直没签书面劳动合同，最近公司让我补签并把日期写成入职当天，我有入职登记、考勤和工作群记录。",
      "expectedScenarioLabel": "未签书面劳动合同",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.7,
      "expectedHandoffRequired": false,
      "mustContain": ["双倍工资差额", "劳动合同签订时间", "重庆本地程序路径"],
      "mustAvoid": ["稳赢", "必胜"],
      "requireFollowUp": true
    },
    {
      "id": "prod-overtime-evidence-gap-dadukou",
      "category": "needs_follow_up",
      "narrative": "我在重庆大渡口经常被安排晚上加班和周末值班，但没有额外工资，目前只有排班截图和微信群通知。",
      "expectedScenarioLabel": "加班费/工时争议",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.65,
      "expectedHandoffRequired": false,
      "mustContain": ["工时制度", "排班", "重庆本地程序路径"],
      "mustAvoid": ["仲裁委一定支持"],
      "requireFollowUp": true
    },
    {
      "id": "prod-labor-relation-platform-nanan",
      "category": "platform_relation",
      "narrative": "我在重庆南岸做同城配送，站点要求每天打卡、接单率和请假都要审批，但公司一直说我是合作关系，现在想确认能不能主张劳动关系。",
      "expectedScenarioLabel": "劳动关系认定",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.7,
      "expectedHandoffRequired": false,
      "mustContain": ["管理从属性", "用工控制", "重庆本地程序路径"],
      "mustAvoid": ["必然认定"],
      "requireFollowUp": true
    },
    {
      "id": "prod-social-insurance-gap-banan",
      "category": "clear_claim",
      "narrative": "我在重庆巴南上班，公司停了我的社保三个月，说以后再补，我已经能下载缴费记录和工资流水。",
      "expectedScenarioLabel": "社会保险争议",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.7,
      "expectedHandoffRequired": false,
      "mustContain": ["社保投诉或仲裁路径", "缴费记录", "重庆本地程序路径"],
      "mustAvoid": ["一定补缴成功"],
      "requireFollowUp": true
    },
    {
      "id": "prod-work-injury-incomplete-hechuan",
      "category": "needs_follow_up",
      "narrative": "我在重庆合川工作时受伤，公司说先自己休息，我手里只有诊断证明，还没做工伤认定。",
      "expectedScenarioLabel": "工伤待遇争议",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.65,
      "expectedHandoffRequired": false,
      "mustContain": ["工伤认定", "停工留薪", "重庆本地程序路径"],
      "mustAvoid": ["肯定能拿到"],
      "requireFollowUp": true
    },
    {
      "id": "prod-female-protection-yongchuan",
      "category": "special_protection",
      "narrative": "我在重庆永川怀孕期间被调岗降薪，公司说绩效不行，我保留了调岗通知、工资变化记录和孕检材料。",
      "expectedScenarioLabel": "女职工特殊保护",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.7,
      "expectedHandoffRequired": false,
      "mustContain": ["三期保护", "调岗降薪", "重庆本地程序路径"],
      "mustAvoid": ["一定违法"],
      "requireFollowUp": true
    },
    {
      "id": "prod-non-compete-unclear-liangjiang",
      "category": "special_protection",
      "narrative": "我在重庆两江新区离职后收到竞业限制通知，但公司之前有没有按月给竞业补偿我现在记不清，只留着协议照片。",
      "expectedScenarioLabel": "竞业限制争议",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.65,
      "expectedHandoffRequired": false,
      "mustContain": ["补偿支付", "限制范围", "重庆本地程序路径"],
      "mustAvoid": ["公司一定无权主张"],
      "requireFollowUp": true
    },
    {
      "id": "prod-pay-benefits-furlough-fuling",
      "category": "benefits",
      "narrative": "我在重庆涪陵上班，公司停工停产后只按很低的标准发生活费，没有书面说明，我想知道能不能申请仲裁。",
      "expectedScenarioLabel": "工资福利/休假争议",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.7,
      "expectedHandoffRequired": false,
      "mustContain": ["停工停产", "拆分金额", "重庆本地程序路径"],
      "mustAvoid": ["一定按最低工资全额支持"],
      "requireFollowUp": true
    },
    {
      "id": "prod-mixed-three-claims-jiulongpo",
      "category": "mixed_claims",
      "narrative": "我在重庆九龙坡上班，公司拖欠工资三个月，还把我辞退了，也一直没签劳动合同，微信、银行流水和打卡记录都还在。",
      "expectedScenarioLabel": "混合争议",
      "expectedRiskLevel": "low",
      "expectedCitationCount": 3,
      "expectedMinConfidence": 0.72,
      "expectedHandoffRequired": false,
      "mustContain": ["拆分争议点", "三个独立主张", "重庆本地程序路径"],
      "mustAvoid": ["稳赢"],
      "requireFollowUp": true
    },
    {
      "id": "prod-unknown-vague-consult",
      "category": "low_confidence_handoff",
      "narrative": "我在重庆工作时遇到一些问题，想先问下是不是可以仲裁，具体情况我还没整理。",
      "expectedScenarioLabel": "未识别场景",
      "expectedRiskLevel": "high",
      "expectedCitationCount": 2,
      "expectedMinConfidence": 0.2,
      "expectedHandoffRequired": true,
      "mustContain": ["补齐关键事实", "不构成法律意见"],
      "mustAvoid": ["稳赢", "一定支持", "偏向劳动者"],
      "requireFollowUp": true
    }
  ]
}
